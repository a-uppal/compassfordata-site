# =============================================================================
# DATA Compass Installer — Declarative Input
# =============================================================================
# This file collects every answer the installer needs, so the install runs
# without interactive prompts. Submit it for security review *before* running
# the install; the install itself becomes a 5–10 minute non-interactive step.
#
# Use with:
#   sudo ./compass-setup.sh --config /path/to/compass-install.env
#
# Behavior:
#   • Bash sources this file. Quote any value containing spaces.
#   • Comments start with '#'.
#   • Empty values are treated as "not provided" and may trigger prompts at
#     runtime (or fail validation, depending on the field).
#   • The installer validates every field BEFORE making any change to the host.
#     If validation fails, it prints all errors at once and exits with code 2;
#     no partial install.
#
# Secrets policy:
#   • NEVER put secrets (API keys, passwords) directly in this file.
#   • Reference them via *_ENV (env var name) or *_FILE (path to file).
#   • If you reference a secret via _ENV, the operator must `export VAR=...`
#     before invoking the installer. Recommended for short-lived sessions.
#   • If you reference a secret via _FILE, the file must be readable only by
#     the operator account (mode 0600). Recommended for IT-managed secrets.
#   • You cannot mix _ENV and _FILE for the same secret. Pick one.
# =============================================================================


# ---------------------------------------------------------------------------
# REQUIRED — deployment shape
# ---------------------------------------------------------------------------

# Where to deploy DATA Compass. Allowed values:
#   docker      — Docker Compose on a Linux host (the typical pharma path).
#                 Use this for any AWS EC2, on-prem, or self-managed cloud VM
#                 deployment. The installer does not need to know it is AWS;
#                 it just needs Linux + Docker.
#   air-gapped  — Docker Compose using an offline image bundle (no internet).
#                 Use for secure environments with no outbound internet.
#   azure       — Azure App Service + managed PostgreSQL. The installer
#                 provisions Azure resources in your tenant on your behalf.
#                 (Most pharma customers will NOT use this path — security
#                 review typically prefers a managed VM + the 'docker' option.
#                 Listed here for completeness; under review for v1.2.)
#
# Why there is no AWS option:
#   AWS App Runner + RDS support was removed in v1.1.4 — App Runner cannot
#   pull from GHCR, so it was architecturally broken. The pharma AWS pattern
#   (bring your own EC2, install via Docker Compose) uses DEPLOYMENT_TYPE=docker
#   above; the installer does not need an AWS-specific branch for that case.
DEPLOYMENT_TYPE=docker

# Absolute path to install the application files. Default: /opt/compass
INSTALL_DIR=/opt/compass

# Path to a license file (.lic), or empty for 30-day evaluation mode.
# In evaluation mode all modules are unlocked but a banner is shown.
LICENSE_FILE=


# ---------------------------------------------------------------------------
# REQUIRED — initial admin user
# ---------------------------------------------------------------------------

# Email address used to log in to the Compass UI for the first time.
# Must be a valid email (validator checks: contains @ and .).
ADMIN_EMAIL=admin@example.com

# Display name shown in the UI.
ADMIN_NAME="Site Administrator"

# Organization shown in the UI; informational only.
ADMIN_ORG="Example Corp"

# Admin password — pick ONE of these two; the other must stay commented.
ADMIN_PASSWORD_ENV=ADMIN_PASSWORD
# ADMIN_PASSWORD_FILE=/run/secrets/compass-admin-password
#
# Password rules: minimum 12 characters, must include letter, digit, and a
# non-alphanumeric character. The validator checks the actual delivered value
# (via the env var or file) against these rules before installing.


# ---------------------------------------------------------------------------
# REQUIRED — AI provider (explicit three-way choice)
# ---------------------------------------------------------------------------
#
# DATA Compass uses one LLM provider for in-app AI features. You must pick
# one of THREE values explicitly — leaving this blank is rejected.
#
#   anthropic   Claude via the Anthropic API
#               Configure ANTHROPIC_API_KEY_ENV or ANTHROPIC_API_KEY_FILE.
#
#   openai      GPT-4o (or compatible) via the OpenAI API
#               Configure OPENAI_API_KEY_ENV or OPENAI_API_KEY_FILE.
#
#   none        Install with NO LLM provider. AI features are disabled at
#               runtime. This is a real, supported choice — pharma operators
#               who decline to send any data to a third-party LLM can pick
#               this and still run the FAIR / DQ / ML / governance modules.
#
# Why explicit?  "AI: none" is an auditable decision; "AI: blank" is a field
# someone forgot to fill in. Compliance reviewers should be able to tell
# the difference.

AI_PROVIDER_PRIMARY=none             # anthropic | openai | none

# Anthropic — pick ONE of these two if AI_PROVIDER_PRIMARY=anthropic.
# Leave both empty if AI_PROVIDER_PRIMARY=openai or =none.
ANTHROPIC_API_KEY_ENV=
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic-api-key

# OpenAI — pick ONE of these two if AI_PROVIDER_PRIMARY=openai.
# Leave both empty if AI_PROVIDER_PRIMARY=anthropic or =none.
OPENAI_API_KEY_ENV=
# OPENAI_API_KEY_FILE=/run/secrets/openai-api-key


# ---------------------------------------------------------------------------
# OPTIONAL — networking
# ---------------------------------------------------------------------------

# Corporate proxy (full URL with scheme).  Empty = no proxy.
# Example: http://proxy.corp.example.com:8080
PROXY_URL=

# Ports the application listens on (host-side). Validator confirms they are
# free at install time.
COMPASS_PORT=3001
POSTGRES_PORT=5432


# ---------------------------------------------------------------------------
# OPTIONAL — installer behavior
# ---------------------------------------------------------------------------

# Behavior when prereq WARNs are emitted (low memory / low disk / low CPU).
#   false  — installer halts, prints all warnings, requires CONFIRM_WARNS=true
#            to be set in the env to continue. Default. Safest.
#   true   — installer logs warnings and proceeds without confirmation.
#            Use only for CI/automation pipelines you control.
PROCEED_ON_WARN=false


# ---------------------------------------------------------------------------
# PREREQUISITES (informational — the validator enforces these)
# ---------------------------------------------------------------------------
# Docker and Docker Compose are STRICT PREREQUISITES. If either is missing
# or below the supported version, the installer fails fast at validation
# with a clear message. The installer does NOT install Docker for you;
# Docker installation is a host-level decision that belongs with your IT /
# cloud team, who will validate it against your organization's baseline.
#
# Required versions:
#   Docker Engine    >= 24.0
#   Docker Compose   >= v2 (the 'docker compose' subcommand, not the older
#                          standalone 'docker-compose' binary)
#
# If you need a vetted Docker install recipe to hand to your cloud team,
# we ship one at:  deploy/install-docker.sh
# (Run it standalone before the Compass installer; we never invoke it for you.)


# ---------------------------------------------------------------------------
# AZURE — required only if DEPLOYMENT_TYPE=azure (else ignored)
# ---------------------------------------------------------------------------

AZURE_RESOURCE_GROUP=
AZURE_LOCATION=eastus
AZURE_APP_NAME=
AZURE_DB_NAME=
AZURE_DB_USER=

# Azure DB password — pick ONE.
AZURE_DB_PASSWORD_ENV=AZURE_DB_PASSWORD
# AZURE_DB_PASSWORD_FILE=/run/secrets/compass-azure-db-password
